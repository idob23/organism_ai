# OpenAI / proxy settings (required)
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.proxyapi.ru/openai/v1

# API keys (comma-separated or JSON list)
API_KEYS=org_0123456789abcdef0123456789abcdef

# Tier overrides (JSON dict, optional — default tier is "free")
# API_KEY_TIERS={"org_0123456789abcdef0123456789abcdef": "pro"}

# Usage DB path (optional, default: usage.db)
# USAGE_DB_PATH=usage.db
