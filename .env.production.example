# Organism AI — Production Environment
# Copy to .env and fill in real values

# === REQUIRED ===
ANTHROPIC_API_KEY=sk-ant-your-key-here
TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_ALLOWED_USERS=123456789

# === DATABASE ===
# Managed by docker-compose — do not change unless external DB
POSTGRES_PASSWORD=change-me-in-production

# === SEARCH ===
TAVILY_API_KEY=tvly-your-key-here

# === EMBEDDINGS (OpenAI proxy) ===
OPENAI_API_KEY=your-key-here
OPENAI_BASE_URL=https://api.proxyapi.ru/openai/v1

# === MONITORING ===
TELEGRAM_ERROR_BOT_TOKEN=your-error-bot-token
TELEGRAM_ERROR_CHAT_ID=-1001234567890

# === ARTEL CONFIG ===
ARTEL_ID=artel_default

# === OPTIONAL ===
LOG_LEVEL=INFO
SANDBOX_TIMEOUT=30
SANDBOX_CPU=0.5
SANDBOX_MEMORY=256m
LLM_FAST_MODEL=claude-haiku-4-5-20251001
LLM_BALANCED_MODEL=claude-sonnet-4-6
